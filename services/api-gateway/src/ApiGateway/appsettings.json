{
  "Jwt": {
    "Secret": "CHANGE_ME_IN_ENV",
    "Issuer": "shelvio",
    "Audience": "shelvio-clients"
  },
  "ReverseProxy": {
    "Routes": {
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "content-route": {
        "ClusterId": "content-cluster",
        "Match": { "Path": "/api/content/{**catch-all}" }
      },
      "tracking-route": {
        "ClusterId": "tracking-cluster",
        "Match": { "Path": "/api/tracking/{**catch-all}" }
      },
      "recommendation-route": {
        "ClusterId": "recommendation-cluster",
        "Match": { "Path": "/api/recommendations/{**catch-all}" }
      }
    },
    "Clusters": {
      "user-cluster": {
        "Destinations": {
          "user-service": { "Address": "http://user-service:8080" }
        }
      },
      "content-cluster": {
        "Destinations": {
          "content-service": { "Address": "http://content-service:3000" }
        }
      },
      "tracking-cluster": {
        "Destinations": {
          "tracking-service": { "Address": "http://tracking-service:8080" }
        }
      },
      "recommendation-cluster": {
        "Destinations": {
          "recommendation-service": { "Address": "http://recommendation-service:8000" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
